PORT=5000
NODE_ENV=development

# MongoDB Atlas SRV URI. Example:
# mongodb+srv://<db_user>:<password>@cluster0.xxxxx.mongodb.net/awareness_journal?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<db_user>:<password>@<cluster-host>/awareness_journal?retryWrites=true&w=majority

JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
